# ============================================================
# Chativa Email API — Environment Variables
# Copy to .env for local dev. Set these in Railway Variables
# for production deployment.
# ============================================================

# ── Required ─────────────────────────────────────────────────

# Brevo API key (Settings → API Keys in Brevo dashboard)
BREVO_API_KEY=your_brevo_api_key_here

# 256-bit secret for signing JWTs
# Generate: openssl rand -hex 32
JWT_SECRET=your_256_bit_secret_here

# Secret for verifying Brevo inbound webhook HMAC-SHA256 signatures
# Set this same value in Brevo → Inbound Parsing → Webhook secret
WEBHOOK_SECRET=your_webhook_secret_here

# Redis connection URL (Railway provides this automatically as REDIS_URL)
REDIS_URL=redis://localhost:6379

# ── Server ────────────────────────────────────────────────────

# Port the Express server listens on (Railway sets this automatically)
PORT=3001

# Environment: development | production
NODE_ENV=production

# ── URLs ──────────────────────────────────────────────────────

# Public base URL of this API (no trailing slash)
API_BASE_URL=https://api.chativa.pro

# Frontend origin allowed by CORS (no trailing slash)
FRONTEND_URL=https://chativa.pro

# ── Database ──────────────────────────────────────────────────

# SQLite file path. On Railway, use a persistent volume mounted at /data
# and set DB_PATH=/data/chativa.db
# WARNING: Without a persistent volume, data is lost on redeploy.
DB_PATH=/data/chativa.db

# ── Email / DKIM ──────────────────────────────────────────────

# Set to 'true' once DKIM DNS records are configured in Brevo dashboard
DKIM_CONFIGURED=false

# ── Spam Scoring ──────────────────────────────────────────────

# Emails with score >= threshold are flagged as spam (default: 5)
SPAM_THRESHOLD=5

# Signal weights (tune to adjust sensitivity)
SPAM_W_KEYWORDS=2.0
SPAM_W_DOMAIN_MISMATCH=1.5
SPAM_W_LINK_DENSITY=1.5
SPAM_W_DISPOSABLE_DOMAIN=3.0
SPAM_W_NO_MX=2.0
SPAM_W_TEXT_LINK_RATIO=1.0
